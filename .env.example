# Django
DJANGO_SECRET_KEY=dev-secret-key-change-me
DJANGO_DEBUG=1
DJANGO_ALLOWED_HOSTS=127.0.0.1,localhost

# Database
POSTGRES_DB=izhs
POSTGRES_USER=izhs
POSTGRES_PASSWORD=izhs
POSTGRES_HOST=127.0.0.1
POSTGRES_PORT=5432

# Redis
REDIS_URL=redis://127.0.0.1:6379/0

# Email — SMTP Yandex. EMAIL_HOST_PASSWORD = пароль приложения (id.yandex.ru -> Безопасность).
# Если пустой — заявки уходят в console runserver, не падают.
EMAIL_HOST=smtp.yandex.ru
EMAIL_PORT=465
EMAIL_USE_SSL=1
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
DEFAULT_FROM_EMAIL=
LEADS_NOTIFY_EMAIL=

# Frontend -> Backend
NEXT_PUBLIC_API_BASE_URL=http://127.0.0.1:8000
