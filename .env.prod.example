# ============================================================
# Production .env (копируется на VPS как .env.prod)
# ВАЖНО: сгенерируй новые секреты, не используй dev-значения!
#   python -c "import secrets; print(secrets.token_urlsafe(50))"
# ============================================================

# --- Django ---------------------------------------------------
DJANGO_SECRET_KEY=CHANGE_ME_50_RANDOM_CHARS
DJANGO_DEBUG=0
DJANGO_ALLOWED_HOSTS=remstroy70.ru,www.remstroy70.ru
CSRF_TRUSTED_ORIGINS=https://remstroy70.ru,https://www.remstroy70.ru
CORS_ALLOWED_ORIGINS=https://remstroy70.ru,https://www.remstroy70.ru
SECURE_SSL_REDIRECT=1
SECURE_HSTS_SECONDS=31536000

# --- Database (Postgres внутри docker-compose) ----------------
POSTGRES_DB=izhs
POSTGRES_USER=izhs
POSTGRES_PASSWORD=CHANGE_ME_STRONG_DB_PASSWORD
POSTGRES_HOST=db
POSTGRES_PORT=5432

# --- Redis ----------------------------------------------------
REDIS_URL=redis://redis:6379/0

# --- Email (Yandex SMTP) --------------------------------------
EMAIL_HOST=smtp.yandex.ru
EMAIL_PORT=465
EMAIL_USE_SSL=1
EMAIL_HOST_USER=remstroyreg70@yandex.ru
EMAIL_HOST_PASSWORD=CHANGE_ME_YANDEX_APP_PASSWORD
DEFAULT_FROM_EMAIL=remstroyreg70@yandex.ru
LEADS_NOTIFY_EMAIL=remstroyreg70@yandex.ru

# --- Frontend → Backend ---------------------------------------
NEXT_PUBLIC_API_BASE_URL=https://remstroy70.ru

# --- Timeweb S3 (object storage для media) --------------------
USE_S3=1
S3_ENDPOINT_URL=https://s3.twcstorage.ru
S3_BUCKET_NAME=
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_REGION_NAME=ru-1
# опционально — кастомный домен (CDN), если настроен
S3_CUSTOM_DOMAIN=

# --- Sentry (опционально) -------------------------------------
SENTRY_DSN=
SENTRY_ENV=production
SENTRY_TRACES_SAMPLE_RATE=0.1

# --- Docker images (заполняются GitHub Actions при деплое) ----
BACKEND_IMAGE=ghcr.io/USER/izhs-platform-backend:latest
FRONTEND_IMAGE=ghcr.io/USER/izhs-platform-frontend:latest
